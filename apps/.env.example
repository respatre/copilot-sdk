# ── DevFlow Environment ──────────────────────────────
# GitHub personal access token with Copilot access
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx

# Port for the DevFlow server
PORT=3001

# ── DevFlow Auth (leave empty to disable) ───────────
DEVFLOW_USER=admin
DEVFLOW_PASS=your_secure_password
DEVFLOW_JWT_SECRET=change_me_to_random_string

# ── GitHub OAuth (for repo import) ──────────────────
GITHUB_OAUTH_CLIENT_ID=your_oauth_app_client_id
GITHUB_OAUTH_CLIENT_SECRET=your_oauth_app_client_secret
GITHUB_OAUTH_REDIRECT_URI=http://localhost:3001/api/github/oauth/callback

# Optional: path to copilot-cli binary (if not on PATH)
# COPILOT_CLI_PATH=/usr/local/bin/copilot-cli

# Optional: connect to an external Copilot CLI server
# CLI_URL=http://localhost:9090
